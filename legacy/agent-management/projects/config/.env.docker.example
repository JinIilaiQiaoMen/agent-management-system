# ============================================
# Docker 部署环境变量配置示例
# ============================================
# 复制此文件为 .env 并填写实际值
# cp .env.docker.example .env
# ============================================

# ============================================
# 应用配置
# ============================================
NODE_ENV=production
PORT=5000

# ============================================
# 数据库配置
# ============================================
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://agent_user:your_secure_password_here@postgres:5432/agent_management

# ============================================
# Coze API 配置
# ============================================
COZE_API_KEY=your_coze_api_key_here
COZE_LLM_API_KEY=your_llm_api_key_here
COZE_LLM_BASE_URL=your_llm_base_url_here
COZE_WEB_SEARCH_API_KEY=your_web_search_api_key_here

# ============================================
# 对象存储配置
# ============================================
COZE_BUCKET_ENDPOINT_URL=your_bucket_endpoint_url_here
COZE_BUCKET_NAME=your_bucket_name_here
COZE_BUCKET_REGION=your_bucket_region_here

# ============================================
# API 认证配置
# ============================================
# 主 API Key（拥有所有权限）
API_MASTER_KEY=sk-your_master_api_key_here

# 客户端 API Key（有限权限）
API_CLIENT_KEY_1=sk-your_client_api_key_1_here
API_CLIENT_KEY_2=sk-your_client_api_key_2_here

# ============================================
# 安全配置（请使用强随机字符串）
# ============================================
JWT_SECRET=your_jwt_secret_here_at_least_32_chars
API_SECRET_KEY=your_api_secret_key_here_at_least_32_chars
SESSION_SECRET=your_session_secret_key_here_at_least_32_chars
PASSWORD_SALT=your_password_salt_here_at_least_32_chars

# ============================================
# CORS 配置
# ============================================
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# Redis 配置（可选）
# ============================================
REDIS_URL=redis://:your_redis_password_here@redis:6379
REDIS_PASSWORD=your_redis_password_here

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# 功能开关
# ============================================
ENABLE_AUTO_SCALING=false
ENABLE_METRICS=true
ENABLE_HEALTH_CHECK=true
