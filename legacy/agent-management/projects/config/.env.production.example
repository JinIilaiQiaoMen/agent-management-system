# ==========================================
# 生产环境配置示例
# ==========================================
# 复制此文件为 .env.production 并填写实际值
# 重要：所有密钥和密码必须更改为强密码！
# ==========================================

# ==========================================
# 应用配置
# ==========================================
NODE_ENV=production
PORT=5000
APP_NAME=Agent Management System
APP_VERSION=1.0.0
APP_URL=https://your-production-domain.com

# ==========================================
# 数据库配置
# ==========================================
# ⚠️ 使用强密码！
DATABASE_URL=postgresql://agent_user:CHANGE_ME_STRONG_PASSWORD_123@postgres:5432/agent_management

# 数据库连接池配置
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# ==========================================
# Coze Coding SDK配置
# ==========================================
COZE_API_KEY=your_production_api_key_here

# 对象存储配置
COZE_BUCKET_ENDPOINT_URL=https://your-production-bucket.s3.amazonaws.com
COZE_BUCKET_NAME=agent-management-prod
COZE_BUCKET_REGION=us-east-1

# 知识库配置
COZE_KNOWLEDGE_BASE_ID=your_knowledge_base_id

# 大模型配置
COZE_LLM_MODEL=doubao-pro-32k
COZE_LLM_API_KEY=your_production_llm_api_key
COZE_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Web Search配置
COZE_WEB_SEARCH_ENABLED=true
COZE_WEB_SEARCH_API_KEY=your_production_web_search_api_key

# ==========================================
# Redis配置
# ==========================================
# 使用Redis进行缓存和会话管理
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD_123@redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_123
REDIS_DB=0

# ==========================================
# 安全配置
# ==========================================
# ⚠️ JWT密钥必须至少32个字符，使用强随机字符串！
JWT_SECRET=CHANGE_ME_TO_A_VERY_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG_123

# API密钥
API_SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET_KEY_456

# Session密钥
SESSION_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_SECRET_KEY_789

# 密码加密盐值
PASSWORD_SALT=CHANGE_ME_SALT_VALUE_012

# ⚠️ 配置允许的域名，不要使用通配符
ALLOWED_ORIGINS=https://your-production-domain.com,https://www.your-production-domain.com

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=warn
LOG_FILE=/var/log/agent-management/app.log
LOG_MAX_SIZE=50m
LOG_MAX_FILES=30

# ==========================================
# 外部服务配置
# ==========================================
# SMTP配置（邮件通知）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@your-production-domain.com

# ==========================================
# API配置
# ==========================================
API_TIMEOUT=30000
API_RETRY_COUNT=3
API_RATE_LIMIT=60

# ==========================================
# 限流配置
# ==========================================
ENABLE_RATE_LIMIT=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_MAX=60
API_RATE_LIMIT_WINDOW=60000

UPLOAD_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_WINDOW=60000

# ==========================================
# 文件上传配置
# ==========================================
MAX_FILE_SIZE=52428800  # 50MB
ALLOWED_FILE_TYPES=.txt,.md,.pdf,.docx,.xlsx,.pptx,.jpg,.jpeg,.png,.gif,.mp4,.mp3,.wav,.csv,.json
FILE_STORAGE_PATH=/var/uploads

# ==========================================
# 知识库配置
# ==========================================
KNOWLEDGE_BASE_MAX_FILE_SIZE=20971520  # 20MB
KNOWLEDGE_BASE_ALLOWED_TYPES=.txt,.md,.pdf,.docx,.xlsx,.pptx,.csv,.json
DOCUMENT_PARSE_TIMEOUT=60000

# ==========================================
# 任务配置
# ==========================================
TASK_DEFAULT_PRIORITY=medium
TASK_AUTO_ASSIGN_ENABLED=true
TASK_TIMEOUT=3600000

# ==========================================
# 智能体配置
# ==========================================
AGENT_DEFAULT_SYSTEM_PROMPT=You are a helpful AI assistant.
AGENT_CONTEXT_WINDOW=8192
AGENT_MAX_RESPONSE_LENGTH=4096

# ==========================================
# API调整模块配置
# ==========================================
API_CONFIG_DEFAULT_TIMEOUT=30000
API_CONFIG_DEFAULT_RETRY=0
API_CONFIG_DEFAULT_RATE_LIMIT=60

# ==========================================
# 缓存配置
# ==========================================
ENABLE_CACHING=true
CACHE_TTL=3600

# ==========================================
# 功能开关
# ==========================================
ENABLE_RATE_LIMIT=true
ENABLE_CACHING=true
ENABLE_LOGGING=true
ENABLE_ERROR_REPORTING=true
ENABLE_FILE_UPLOAD=true
ENABLE_KNOWLEDGE_BASE=true
ENABLE_API_CONFIG=true
ENABLE_TASK_DELIVERABLE=true

# ==========================================
# 监控和告警
# ==========================================
# Sentry错误追踪（生产环境强烈建议配置）
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# 监控端点
MONITORING_ENDPOINT=https://your-monitoring-service.com/webhook

# 健康检查
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/api/health

# ==========================================
# 备份配置
# ==========================================
# ⚠️ 生产环境强烈建议启用备份
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 每天凌晨2点
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/var/backups/agent-management

# ==========================================
# 开发工具
# ==========================================
# ⚠️ 生产环境必须禁用开发工具
DEVTOOLS_ENABLED=false

# ⚠️ 生产环境不显示详细错误信息
SHOW_DETAILED_ERRORS=false

# ==========================================
# CDN配置（可选）
# ==========================================
CDN_URL=https://cdn.your-production-domain.com

# ==========================================
# 其他配置
# ==========================================
TZ=Asia/Shanghai
LANG=zh_CN.UTF-8
TIMEZONE_OFFSET=8

# ==========================================
# SSL/TLS配置（如果使用反向代理）
# ==========================================
# 这些配置通常由Nginx/Apache处理
# SSL_CERT_PATH=/etc/ssl/certs/your-domain.crt
# SSL_KEY_PATH=/etc/ssl/private/your-domain.key
