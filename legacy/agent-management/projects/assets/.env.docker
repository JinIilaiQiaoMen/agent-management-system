# ==================== 数据库配置 ====================
# PostgreSQL 数据库配置（本地 Docker 部署使用）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_change_this
POSTGRES_DB=ai_system

# 应用使用的数据库连接字符串（Docker 内部）
DATABASE_URL=postgresql://postgres:your_secure_password_change_this@postgres:5432/ai_system

# ==================== Supabase 配置（可选） ====================
# 如果使用 Supabase 作为数据库，填写以下配置
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ==================== ComfyUI 配置 ====================
# ComfyUI 服务端点
NEXT_PUBLIC_COMFYUI_ENDPOINT=http://localhost:8188
COMFYUI_WORKFLOW_PATH=./public/workflows
COMFYUI_OUTPUT_DIR=/workspace/projects/ComfyUI-Service/output
COMFYUI_TIMEOUT=120

# ==================== LLM SDK 配置 ====================
# 使用 coze-coding-dev-sdk，通过 API 接口调用，无需配置密钥

# ==================== JWT 配置 ====================
# JWT 密钥（请使用强密码）
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# ==================== 应用配置 ====================
# 应用名称
NEXT_PUBLIC_APP_NAME=AI智能化企业系统
NEXT_PUBLIC_APP_VERSION=1.0.0

# 环境模式
NODE_ENV=production

# 端口配置
PORT=5000

# ==================== Redis 配置（可选） ====================
# 如果需要缓存功能，可以启用 Redis
REDIS_URL=redis://redis:6379

# ==================== 其他配置 ====================
# 日志级别
LOG_LEVEL=info

# 时区
TZ=Asia/Shanghai
