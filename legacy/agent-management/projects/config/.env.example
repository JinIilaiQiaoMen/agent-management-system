# ==========================================
# 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ==========================================

# ==========================================
# 应用配置
# ==========================================
NODE_ENV=development
PORT=5000

# 应用名称
APP_NAME=Agent Management System

# 应用版本
APP_VERSION=1.0.0

# 应用URL
APP_URL=http://localhost:5000

# ==========================================
# 数据库配置
# ==========================================
# PostgreSQL数据库连接字符串
# 格式：postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_management

# 数据库连接池配置
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ==========================================
# Coze Coding SDK配置
# ==========================================
# Coze API密钥（如果需要）
COZE_API_KEY=your_coze_api_key_here

# Coze Bucket配置（对象存储）
COZE_BUCKET_ENDPOINT_URL=https://your-bucket-endpoint.com
COZE_BUCKET_NAME=your-bucket-name
COZE_BUCKET_REGION=your-region

# Coze知识库配置
COZE_KNOWLEDGE_BASE_ID=your_knowledge_base_id

# Coze大模型配置
COZE_LLM_MODEL=doubao-pro-32k
COZE_LLM_API_KEY=your_llm_api_key
COZE_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Coze Web Search配置
COZE_WEB_SEARCH_ENABLED=true
COZE_WEB_SEARCH_API_KEY=your_web_search_api_key

# ==========================================
# Redis配置（可选，用于缓存和会话）
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# 安全配置
# ==========================================
# JWT密钥（如果使用JWT认证）
JWT_SECRET=your_jwt_secret_here_min_32_characters_long

# API密钥（可选）
API_SECRET_KEY=your_api_secret_key

# Session密钥
SESSION_SECRET=your_session_secret_here

# 密码加密盐值
PASSWORD_SALT=your_salt_value

# 允许的源（CORS）
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=info
LOG_FILE=/var/log/agent-management/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=10

# ==========================================
# 外部服务配置
# ==========================================
# 邮件服务（如果需要）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@your-domain.com

# ==========================================
# API配置
# ==========================================
# API请求超时时间（毫秒）
API_TIMEOUT=30000

# API默认重试次数
API_RETRY_COUNT=3

# API速率限制（请求/分钟）
API_RATE_LIMIT=60

# ==========================================
# 限流配置
# ==========================================
# 全局限流配置（请求/分钟）
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# API限流
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_MAX=60
API_RATE_LIMIT_WINDOW=60000

# 文件上传限流
UPLOAD_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_WINDOW=60000

# ==========================================
# 文件上传配置
# ==========================================
# 最大文件大小（字节）50MB
MAX_FILE_SIZE=52428800

# 允许的文件类型
ALLOWED_FILE_TYPES=.txt,.md,.pdf,.docx,.xlsx,.pptx,.jpg,.jpeg,.png,.gif,.mp4,.mp3,.wav,.csv,.json

# 文件存储路径
FILE_STORAGE_PATH=/tmp/uploads

# ==========================================
# 知识库配置
# ==========================================
# 知识库文件大小限制（字节）20MB
KNOWLEDGE_BASE_MAX_FILE_SIZE=20971520

# 知识库支持的文件类型
KNOWLEDGE_BASE_ALLOWED_TYPES=.txt,.md,.pdf,.docx,.xlsx,.pptx,.csv,.json

# 文档解析超时时间（毫秒）
DOCUMENT_PARSE_TIMEOUT=60000

# ==========================================
# 任务配置
# ==========================================
# 任务默认优先级
TASK_DEFAULT_PRIORITY=medium

# 任务自动分配
TASK_AUTO_ASSIGN_ENABLED=true

# 任务超时时间（毫秒）
TASK_TIMEOUT=3600000

# ==========================================
# 智能体配置
# ==========================================
# 智能体默认系统提示词
AGENT_DEFAULT_SYSTEM_PROMPT=You are a helpful AI assistant.

# 智能体上下文窗口大小
AGENT_CONTEXT_WINDOW=8192

# 智能体最大响应长度
AGENT_MAX_RESPONSE_LENGTH=4096

# ==========================================
# API调整模块配置
# ==========================================
# API配置默认超时（毫秒）
API_CONFIG_DEFAULT_TIMEOUT=30000

# API配置默认重试次数
API_CONFIG_DEFAULT_RETRY=0

# API配置默认速率限制（请求/分钟）
API_CONFIG_DEFAULT_RATE_LIMIT=60

# ==========================================
# 缓存配置
# ==========================================
ENABLE_CACHING=true
CACHE_TTL=3600

# ==========================================
# 功能开关
# ==========================================
ENABLE_RATE_LIMIT=true
ENABLE_CACHING=true
ENABLE_LOGGING=true
ENABLE_ERROR_REPORTING=true
ENABLE_FILE_UPLOAD=true
ENABLE_KNOWLEDGE_BASE=true
ENABLE_API_CONFIG=true
ENABLE_TASK_DELIVERABLE=true

# ==========================================
# 监控和告警
# ==========================================
# Sentry DSN（错误追踪）
SENTRY_DSN=

# 监控端点
MONITORING_ENDPOINT=

# 健康检查端点
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/api/health

# ==========================================
# 备份配置
# ==========================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=/tmp/backups

# ==========================================
# 开发工具
# ==========================================
# 是否启用开发工具（热重载、调试等）
DEVTOOLS_ENABLED=true

# 是否显示详细错误信息
SHOW_DETAILED_ERRORS=true

# ==========================================
# 其他配置
# ==========================================
# 时区
TZ=Asia/Shanghai

# 语言
LANG=zh_CN.UTF-8

# 时区偏移（小时）
TIMEZONE_OFFSET=8
